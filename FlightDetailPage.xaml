<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Uhrzeitrechner.FlightDetailPage"
             Title="Flugdetails">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label x:Name="HeaderLabel" FontSize="Medium" FontAttributes="Bold" />

            <BoxView HeightRequest="1" Color="LightGray" />

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Label Grid.Column="0" Text="Off-Block:" FontSize="Small" TextColor="Gray" />
                <Label Grid.Column="1" x:Name="OffBlockLabel" FontSize="Small" FontAttributes="Bold" />
            </Grid>

            <VerticalStackLayout x:Name="LegsStack" Spacing="6">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Label Text="{Binding}" FontSize="Small" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Label Grid.Column="0" Text="On-Block:" FontSize="Small" TextColor="Gray" />
                <Label Grid.Column="1" x:Name="OnBlockLabel" FontSize="Small" FontAttributes="Bold" />
            </Grid>

            <BoxView HeightRequest="1" Color="LightGray" />

            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                <Label Grid.Row="0" Grid.Column="0" Text="Blockzeit:" FontSize="Small" FontAttributes="Bold" />
                <Label Grid.Row="0" Grid.Column="1" x:Name="BlockTimeLabel" FontSize="Small" FontAttributes="Bold" TextColor="DodgerBlue" />
                <Label Grid.Row="1" Grid.Column="0" Text="Flugzeit:" FontSize="Small" FontAttributes="Bold" />
                <Label Grid.Row="1" Grid.Column="1" x:Name="FlightTimeLabel" FontSize="Small" FontAttributes="Bold" TextColor="DodgerBlue" />
                <Label Grid.Row="2" Grid.Column="0" Text="Landungen:" FontSize="Small" FontAttributes="Bold" />
                <Label Grid.Row="2" Grid.Column="1" x:Name="LandingCountLabel" FontSize="Small" FontAttributes="Bold" TextColor="DodgerBlue" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
