<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Uhrzeitrechner.MainPage"
             Title="Stundenrechner">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="20" RowSpacing="15">

        <!-- Eingabe -->
        <VerticalStackLayout Grid.Row="0" Spacing="20">

            <!-- Aktuelle Zeiten -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="Lokal" FontSize="12" TextColor="Gray" />
                    <Label x:Name="LocalTimeLabel" Text="--:--:--"
                   FontSize="18" FontAttributes="Bold" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1">
                    <Label Text="UTC" FontSize="12" TextColor="Gray" />
                    <Label x:Name="UtcTimeLabel" Text="--:--:--"
                   FontSize="18" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Grid>

            <Label Text="Zeit hinzufügen" FontSize="20" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,Auto,*,Auto" ColumnSpacing="8">
                <Entry x:Name="HoursEntry"
               Grid.Column="0"
               Placeholder="Std"
               Keyboard="Numeric"
               MaxLength="3" />
                <Label Grid.Column="1" Text=":" VerticalOptions="Center" FontSize="20" />
                <Entry x:Name="MinutesEntry"
               Grid.Column="2"
               Placeholder="Min"
               Keyboard="Numeric"
               MaxLength="2" />
                <Button Grid.Column="3"
                Text="+"
                FontSize="20"
                WidthRequest="50"
                Clicked="OnAddClicked" />
            </Grid>
        </VerticalStackLayout>

        <!-- Trenner -->
        <BoxView Grid.Row="1" HeightRequest="1" Color="LightGray" />

        <!-- Liste der Einträge -->
        <CollectionView Grid.Row="2" x:Name="EntriesView">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto" Padding="5,8">
                        <Label Grid.Column="0"
                               Text="{Binding Display}"
                               FontSize="18"
                               VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Text="✕"
                                FontSize="14"
                                WidthRequest="40"
                                HeightRequest="40"
                                BackgroundColor="Transparent"
                                TextColor="Red"
                                Clicked="OnRemoveClicked"
                                CommandParameter="{Binding .}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Summe -->
        <VerticalStackLayout Grid.Row="3" Spacing="10">
            <BoxView HeightRequest="1" Color="LightGray" />
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" Text="Summe:" FontSize="22" FontAttributes="Bold" />
                <Label Grid.Column="1" x:Name="TotalLabel" Text="0:00"
                       FontSize="22" FontAttributes="Bold" TextColor="DodgerBlue" />
            </Grid>
            <Button Text="Alles löschen" Clicked="OnClearClicked" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>
